# ─── Base de datos (REQUERIDO para modo real) ─────────────────────
# Sin esta variable, la app corre en modo demo automáticamente.
#
# Opción A: PostgreSQL local
# DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/dpp_control"
#
# Opción B: Supabase (recomendado para producción)
# Obtener desde: https://supabase.com → Settings → Database → Connection string → URI
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DATABASE_URL="postgresql://user:password@localhost:5432/dpp_control"

# ─── Supabase (Fase 3 en adelante — auth y storage) ───────────────
# NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJh..."
# SUPABASE_SERVICE_ROLE_KEY="eyJh..."

# ─── Auth interna (Fase 7B — REQUERIDO) ──────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-generate-random-min-32-chars"

# ─── Setup de usuario admin (solo para script scripts/create-admin-user.ts) ──
# ADMIN_EMAIL="admin@dpp.pe"
# ADMIN_PASSWORD="tu_contraseña_segura"

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
